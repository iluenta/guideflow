# Supabase Configuration
# Copy this file to .env.local and fill in your actual credentials.
# Get them from: https://app.supabase.com/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Admin (server-side only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin API key for internal admin endpoints (generate a strong random secret, never reuse service role key)
ADMIN_API_KEY=your-admin-api-key-here

# AI APIs
GOOGLE_AI_API_KEY=your-google-ai-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# Maps
GOOGLE_PLACES_API_KEY=your-google-places-api-key-here
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-public-token-here

# App URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
